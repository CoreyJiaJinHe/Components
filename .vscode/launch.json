{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.server:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    },
    {
      "name": "Frontend: Vite Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host localhost --port 5173",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Frontend: Open in Firefox",
      "type": "node-terminal",
      "request": "launch",
      "command": "start firefox http://localhost:5173",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: FastAPI + Vite",
      "configurations": [
        "Backend: FastAPI (uvicorn)",
        "Frontend: Vite Dev Server"
      ],
      "stopAll": true
    },
    {
      "name": "Full Stack + Browser",
      "configurations": [
        "Backend: FastAPI (uvicorn)",
        "Frontend: Vite Dev Server",
        "Frontend: Open in Firefox"
      ],
      "stopAll": true
    }
  ]
}
